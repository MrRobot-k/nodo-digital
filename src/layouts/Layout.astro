---
import '@fontsource-variable/geist';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nodo Digital | Software a la medida con IA — Cd. Victoria',
  description = 'Software a la medida para tu negocio en Cd. Victoria. Automatización con IA, desarrollo web profesional y consultoría tecnológica. Primero te conozco, luego te propongo algo útil.'
} = Astro.props;

const domain = 'https://nodo-digital.vercel.app';
const ogImage = `${domain}/og-image.webp`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="google-site-verification" content="P6C-d4yLexwK-M28UC0et8q49T-JIXKEHltzIs4nnOM" />
    <link rel="icon" type="image/png" href="/robot.png" />
    <link rel="apple-touch-icon" href="/robot.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content="software a la medida Cd. Victoria, desarrollo web Tamaulipas, automatización IA, sistemas de venta, inventario, negocio local, páginas web" />
    <link rel="canonical" href={domain} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={domain} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_MX" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Nodo Digital",
      "description": description,
      "url": domain,
      "image": ogImage,
      "telephone": "+528342550555",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Ciudad Victoria",
        "addressRegion": "Tamaulipas",
        "addressCountry": "MX"
      },
      "areaServed": "Ciudad Victoria, Tamaulipas",
      "priceRange": "$$",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+528342550555",
        "contactType": "sales",
        "availableLanguage": ["Spanish"]
      },
      "sameAs": ["https://wa.me/528342550555"]
    })} />

    <title>{title}</title>
    <Analytics />
    <SpeedInsights />

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.05 });

        document.querySelectorAll(
          '.scroll-reveal, .clip-reveal, .clip-reveal-right, .clip-reveal-top, .stagger-children'
        ).forEach(el => {
          el.classList.add('is-hidden');
          observer.observe(el);
          setTimeout(() => {
            if (!el.classList.contains('revealed')) {
              el.classList.add('revealed');
            }
          }, 4000);
        });
      });
    </script>
  </head>
  <body>
    <a href="#main-content" class="fixed -top-full left-4 z-[60] p-3 bg-white text-zinc-950 text-sm font-medium transition-[top] duration-200 focus:top-4 outline-ring">
      Ir al contenido principal
    </a>
    <div class="grain-overlay" aria-hidden="true" />
    <div id="main-content">
      <slot />
    </div>
  </body>
</html>
