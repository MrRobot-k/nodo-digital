---
---

<section class="relative min-h-[90vh] flex items-center pt-24 pb-20 overflow-hidden">
  {/* Background effects */}
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[--color-accent] rounded-full mix-blend-screen opacity-10 filter blur-[100px] animate-[float-slow_8s_ease-in-out_infinite]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-125 h-125 bg-emerald-800 rounded-full mix-blend-screen opacity-10 filter blur-[128px] animate-[float-slow_10s_ease-in-out_infinite_reverse]"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0MCIgaGVpZ2h0PSI0MCI+PHBhdGggZD0iTTAgMGg0MHY0MEgweiIgZmlsbD0ibm9uZSIvPjxwYXRoIGQ9Ik0wIDAuNWg0ME0wIDM5LjVoNDBNMC41IDB2NDBNMzkuNSAwdjQwIiBzdHJva2U9InJnYmEoMjU1LDI1NSwyNTUsMC4wMykiLz48L3N2Zz4=')] [mask:linear-gradient(180deg,white,rgba(255,255,255,0))] opacity-50"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 w-full">
    <div class="scroll-reveal flex items-center gap-3 mb-12">
      <div class="glass px-4 py-1.5 rounded-full flex items-center gap-2 border border-white/10">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[--color-accent] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[--color-accent]"></span>
        </span>
        <span class="text-xs font-medium tracking-wide text-zinc-300 uppercase">
          Operando en Cd. Victoria
        </span>
      </div>
    </div>

    <div class="grid lg:grid-cols-[1.2fr_1fr] gap-16 lg:gap-20 items-center">
      <div class="scroll-reveal" style="transition-delay: 100ms">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-8" style="line-height: 1.1;">
          <span class="text-gradient">Tecnología premium</span><br/>
          <span class="text-zinc-500">para tu negocio.</span>
        </h1>

        <p class="text-lg md:text-xl text-[--color-ink-2] leading-relaxed max-w-xl mb-12">
          Sistemas web, punto de venta y automatizaciones con IA que escalan contigo.
          Diseño exclusivo, sin plantillas, hecho a la medida.
        </p>

        <div class="flex flex-wrap gap-4 mb-16">
          <a href="#contacto"
             class="group relative inline-flex items-center justify-center gap-2 bg-white text-zinc-950 font-semibold px-8 py-4 rounded-full overflow-hidden transition-transform hover:scale-105"
          >
            <div class="absolute inset-0 bg-linear-to-r from-emerald-400 to-teal-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <span class="relative z-10 flex items-center gap-2 group-hover:text-zinc-900">
              Iniciar Proyecto
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
          <a href="#servicios"
             class="inline-flex items-center justify-center gap-2 glass text-[--color-ink] font-medium px-8 py-4 rounded-full transition-colors hover:bg-white/10 border border-white/10"
          >
            Explorar soluciones
          </a>
        </div>

        <div class="flex flex-wrap items-center gap-6 text-sm text-[--color-ink-2]">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[--color-accent]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Soporte Premium
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[--color-accent]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Soluciones a la medida
          </span>
        </div>
      </div>

      <div class="scroll-reveal relative" style="transition-delay: 250ms">
        <div class="absolute inset-0 bg-linear-to-tr from-[--color-accent] to-transparent opacity-10 rounded-3xl blur-2xl"></div>
        <div class="glass-card rounded-3xl p-8 md:p-10 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-[--color-accent] rounded-full mix-blend-screen opacity-10 filter blur-[32px]"></div>
          
          <span class="inline-block px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs text-[--color-accent] font-mono mb-8">
            PROCESO SIMPLE
          </span>
          
          <div class="space-y-8 relative z-10">
            <div class="flex gap-5 group">
              <div class="shrink-0 w-12 h-12 rounded-2xl glass flex items-center justify-center text-sm font-mono text-[--color-accent] border border-white/10 group-hover:scale-110 transition-transform">01</div>
              <div>
                <h4 class="text-lg font-medium text-white mb-1">Diagnóstico</h4>
                <p class="text-sm text-zinc-400 leading-relaxed">Analizamos tus cuellos de botella sin compromiso ni costo.</p>
              </div>
            </div>
            <div class="flex gap-5 group">
              <div class="shrink-0 w-12 h-12 rounded-2xl glass flex items-center justify-center text-sm font-mono text-[--color-accent] border border-white/10 group-hover:scale-110 transition-transform">02</div>
              <div>
                <h4 class="text-lg font-medium text-white mb-1">Propuesta</h4>
                <p class="text-sm text-zinc-400 leading-relaxed">Arquitectura clara, presupuestos transparentes y tiempos definidos.</p>
              </div>
            </div>
            <div class="flex gap-5 group">
              <div class="shrink-0 w-12 h-12 rounded-2xl glass flex items-center justify-center text-sm font-mono text-[--color-accent] border border-white/10 group-hover:scale-110 transition-transform">03</div>
              <div>
                <h4 class="text-lg font-medium text-white mb-1">Ejecución</h4>
                <p class="text-sm text-zinc-400 leading-relaxed">Despliegue rápido, capacitación y soporte continuo.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
