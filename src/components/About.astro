---
const pasos = [
  {
    titulo: "Diagnóstico sin costo",
    texto: "Agendamos una videollamada o reunión presencial. Me cuentas cómo funciona tu negocio y qué procesos te gustaría optimizar.",
  },
  {
    titulo: "Propuesta clara",
    texto: "Recibes una propuesta con tecnologías, tiempos y costos exactos. Sin tecnicismos ni letras chiquitas.",
  },
  {
    titulo: "Construcción y entrega",
    texto: "Desarrollo el sistema con tecnologías web estables y lo pongo en producción. Incluye pruebas y documentación.",
  },
  {
    titulo: "Acompañamiento continuo",
    texto: "Soporte técnico después de la entrega. Actualizaciones, ajustes y mejoras conforme tu negocio crece.",
  },
];

const stats = [
  { valor: "100%", label: "Enfoque Local" },
  { valor: "+10", label: "Años de Experiencia" },
  { valor: "24/7", label: "Soporte Técnico" },
];
---

<section id="about" class="py-32 md:py-44 px-6 relative">
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-[1.1fr_1.3fr] gap-16 lg:gap-28 items-start">

      <!-- Left: Sticky intro -->
      <div class="lg:sticky lg:top-32 scroll-reveal">
        <h2 class="text-[clamp(32px,5vw,52px)] font-bold tracking-tight text-white leading-[0.92] mb-6">
          Primero te <span class="text-[#5ed29c]">conozco</span>,<br />
          luego te propongo<br />
          <span class="text-[#5ed29c]">algo útil</span>
        </h2>

        <p class="text-base md:text-lg text-zinc-500 leading-relaxed mb-14 max-w-md">
          Opero desde Cd. Victoria, Tamaulipas. Conozco los retos diarios de los negocios locales porque trabajo con ellos.
        </p>

        <div class="grid grid-cols-3 gap-6 mb-12">
          {stats.map(stat => (
            <div>
              <span class="text-3xl md:text-4xl font-bold text-white block mb-1">{stat.valor}</span>
              <span class="text-[10px] text-zinc-600 uppercase tracking-wider font-medium">{stat.label}</span>
            </div>
          ))}
        </div>

        <div class="border-t border-white/[0.06] pt-6">
          <p class="text-sm text-zinc-500 leading-relaxed">
            <span class="text-white font-medium">Garantía de calidad</span><br />
            Todo el código se prueba antes de entregarse. Sin sorpresas, sin deuda técnica heredada.
          </p>
        </div>
      </div>

      <!-- Right: Accordion steps -->
      <div class="space-y-0">
        {pasos.map((p, i) => (
          <div class={i > 0 ? "border-t border-white/[0.06]" : ""}>
            <details class="group" open={i === 0}>
              <summary class="flex items-center gap-5 py-8 cursor-pointer list-none">
                <span class="font-mono text-[11px] text-zinc-600 font-bold tracking-wider shrink-0">
                  {`0${i + 1}`}
                </span>
                <h3 class="text-lg md:text-xl font-medium text-white flex-1">{p.titulo}</h3>
                <div class="w-8 h-8 border border-white/[0.06] flex items-center justify-center transition-[border-color,background-color] duration-300 group-open:border-[#5ed29c]/30 group-open:bg-[#5ed29c]/[0.05]">
                  <svg class="w-3.5 h-3.5 text-zinc-500 transition-transform duration-300 group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14" />
                    <path d="M5 12h14" />
                  </svg>
                </div>
              </summary>
              <div class="pb-8 pl-[3.25rem]">
                <p class="text-zinc-400 leading-relaxed">{p.texto}</p>
              </div>
            </details>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
