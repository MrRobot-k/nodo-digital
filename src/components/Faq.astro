---
import FaqAccordion from './FaqAccordion';
---

<section id="faq" class="py-32 md:py-44 px-6 relative">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="scroll-reveal mb-16 md:mb-20">
      <h2 class="text-[clamp(28px,5vw,44px)] font-bold tracking-tight text-foreground leading-[0.92] mb-5">
        Preguntas <span class="text-accent-val">frecuentes</span>
      </h2>
      <p class="text-ink-2 leading-relaxed max-w-lg">
        Respuestas claras sobre cómo trabajamos, sin rodeos.
      </p>
    </div>

    <!-- FAQ Accordion -->
    <FaqAccordion client:load />
  </div>
</section>
