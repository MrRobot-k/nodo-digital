---
const servicios = [
  {
    titulo: "Sistemas Inteligentes",
    texto: "Software hecho a tu medida. Punto de venta, control de inventario o gestión integral. Olvídate de los sistemas lentos y genéricos.",
    tags: ["Arquitectura escalable", "Soporte VIP"],
  },
  {
    titulo: "Presencia Web",
    texto: "Páginas súper rápidas, optimizadas y hermosas. Integradas con WhatsApp para capturar leads 24/7.",
    tags: ["Pago único"],
  },
  {
    titulo: "Automatización con IA",
    texto: "La IA responde por ti, organiza tus datos y genera reportes. Delega el trabajo aburrido y enfócate en crecer tu negocio.",
    tags: ["Bots 24/7", "Eficiencia total"],
  },
  {
    titulo: "Asesoría Premium",
    texto: "Descubramos dónde pierdes tiempo y dinero. Diagnóstico completo sin costo para crear tu ruta de modernización.",
    tags: ["Sin compromiso", "Remoto/Local"],
  }
];
---

<section id="servicios" class="py-24 md:py-32 px-6 relative">
  <div class="max-w-6xl mx-auto">
    <div class="scroll-reveal mb-24">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-[0.95] mb-6 max-w-4xl">
        Sistemas que transforman tu forma de trabajar
      </h2>
      <p class="text-lg text-zinc-400 leading-relaxed max-w-2xl">
        Soluciones técnicas de alto nivel diseñadas específicamente para automatizar, vender más y perder menos tiempo.
      </p>
    </div>

    <div class="scroll-reveal">
      {servicios.map((s, i) => (
        <div class={i > 0 ? "border-t border-white/[.06] pt-10 mt-10" : ""}>
          <div class="flex items-start gap-6">
            <span class="font-mono text-[11px] text-zinc-600 font-bold tracking-wider shrink-0 mt-1.5">
              {(i + 1).toString().padStart(2, "0")}
            </span>
            <div class={i === 0 ? "flex-1" : ""}>
              <h3 class={i === 0 ? "text-2xl md:text-3xl font-bold text-white mb-3" : "text-xl font-semibold text-white mb-2"}>
                {s.titulo}
              </h3>
              <p class="text-zinc-400 leading-relaxed max-w-2xl mb-3">{s.texto}</p>
              <div class="flex flex-wrap gap-x-4 gap-y-1">
                {s.tags.map(tag => (
                  <span class="font-mono text-xs text-zinc-500">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="scroll-reveal mt-24 pt-12 border-t border-white/[.06] flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h4 class="text-xl font-medium text-white mb-2">¿No estás seguro por dónde empezar?</h4>
        <p class="text-zinc-400">Podemos hacer un diagnóstico de tus procesos sin ningún costo.</p>
      </div>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-white text-zinc-950 font-semibold px-6 py-3 transition-transform hover:scale-[1.02] active:scale-[0.98]"
      >
        Agendar llamada
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
