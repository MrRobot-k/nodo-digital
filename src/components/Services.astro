---
import { Badge } from './ui/badge';

const servicios = [
  {
    id: "01",
    titulo: "Software a la medida",
    texto: "Apps nativas para Mac, Windows, iOS, Android y Linux — escritorio, móvil o web. El software se adapta a tu negocio, no al revés.",
    tags: ["Multiplataforma", "Arquitectura escalable", "Soporte continuo"],
    imagen: "/images/software-dev.jpg",
  },
  {
    id: "02",
    titulo: "Presencia web profesional",
    texto: "Páginas rápidas, optimizadas y conectadas con WhatsApp para capturar clientes 24/7.",
    tags: ["Pago único", "Rendimiento premium"],
    imagen: "/images/web-presence.jpg",
  },
  {
    id: "03",
    titulo: "Automatización con IA",
    texto: "Chatbots inteligentes que responden a tus clientes, organizan datos y generan reportes automáticos.",
    tags: ["Bots 24/7", "Sin intervención"],
    imagen: "/images/ai-automation.jpg",
  },
  {
    id: "04",
    titulo: "Consultoría tecnológica",
    texto: "Diagnóstico de procesos operativos. Identificamos áreas de mejora en tiempo y costo.",
    tags: ["Sin costo", "Sin compromiso"],
    imagen: "/images/consulting.jpg",
  },
];
---

<section id="servicios" class="py-32 md:py-44 px-6 relative">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-20 md:mb-28">
      <div class="scroll-reveal">
        <h2 class="text-[clamp(36px,6vw,64px)] font-bold tracking-tight text-foreground leading-[0.92] max-w-4xl">
          Para cualquier<br />
          <span class="text-accent-val">dispositivo, en cualquier lugar</span>
        </h2>
      </div>
      <p class="text-base md:text-lg text-ink-2 leading-relaxed max-w-xl mt-6">
        Apps de escritorio, móviles y web que funcionan como necesitas — no como el software de siempre te obliga.
      </p>
    </div>

    <!-- Numbered narrative -->
    <div class="space-y-24 md:space-y-32">
      {servicios.map((svc, i) => (
        <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
          <!-- Text side -->
          <div class={`scroll-reveal ${i % 2 === 1 ? "md:order-2" : "md:order-1"}`}>
            <span class="font-mono text-[13px] text-ink-3 font-bold tracking-[0.15em] block mb-4">
              {svc.id}
            </span>
            <h3 class="text-3xl md:text-4xl font-semibold text-foreground leading-[1.08] mb-5">
              {svc.titulo}
            </h3>
            <p class="text-ink-2 leading-relaxed mb-8 max-w-md">
              {svc.texto}
            </p>
            <div class="flex flex-wrap gap-2 mb-8">
              {svc.tags.map(tag => (
                <Badge variant="secondary" className="text-[11px] px-3 py-1 font-medium tracking-wide border border-[var(--color-border-val)]">
                  {tag}
                </Badge>
              ))}
            </div>
            {i === servicios.length - 1 && (
              <a
                href="#contacto"
                class="group/btn inline-flex items-center gap-3 bg-primary text-primary-foreground font-medium text-sm px-7 py-3.5 rounded-full transition-[background-color,box-shadow] duration-200 ease-out hover:bg-[var(--color-accent-h-val)] hover:shadow-[0_0_25px_var(--color-accent-subtle-val)] active:scale-[0.96]"
              >
                Iniciar proyecto
                <svg class="w-4 h-4 transition-transform duration-200 group-hover/btn:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            )}
          </div>

          <!-- Image side -->
          <div class={`relative ${i % 2 === 1 ? "md:order-1" : "md:order-2"}`}>
            <div class="relative overflow-hidden rounded-2xl">
              <img
                src={svc.imagen}
                alt={svc.titulo}
                class="w-full h-[300px] md:h-[400px] object-cover transition-transform duration-700 ease-out hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-tr from-background/60 via-background/10 to-transparent pointer-events-none" />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
