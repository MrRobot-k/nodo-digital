---
import { LucideIcon } from 'lucide-react'; // Not using it directly here, we'll use SVGs directly for simplicity, but good to know we have lucide.

const servicios = [
  {
    titulo: "Sistemas Inteligentes",
    texto: "Software hecho a tu medida. Punto de venta, control de inventario o gestión integral. Olvídate de los sistemas lentos y genéricos.",
    tags: ["Arquitectura escalable", "Soporte VIP"],
    colSpan: "md:col-span-2",
    icon: '<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h.01"/><path d="M7 20v-4"/><path d="M12 20v-8"/><path d="M17 20V8"/><path d="M22 4v16"/></svg>'
  },
  {
    titulo: "Presencia Web",
    texto: "Páginas súper rápidas, optimizadas y hermosas. Integradas con WhatsApp para capturar leads 24/7.",
    tags: ["Pago único"],
    colSpan: "md:col-span-1",
    icon: '<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="m9 21-3-9"/></svg>'
  },
  {
    titulo: "Automatización con IA",
    texto: "La IA responde por ti, organiza tus datos y genera reportes. Delega el trabajo aburrido y enfócate en crecer tu negocio.",
    tags: ["Bots 24/7", "Eficiencia total"],
    colSpan: "md:col-span-1",
    icon: '<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m17 5-5-3-5 3"/><path d="m17 19-5 3-5-3"/></svg>'
  },
  {
    titulo: "Asesoría Premium",
    texto: "Descubramos dónde pierdes tiempo y dinero. Diagnóstico completo sin costo para crear tu ruta de modernización.",
    tags: ["Sin compromiso", "Remoto/Local"],
    colSpan: "md:col-span-2",
    icon: '<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>'
  }
];
---

<section id="servicios" class="py-24 md:py-32 px-6 relative">
  {/* Ambient background blur */}
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w200 h-150 bg-[--color-accent] rounded-full mix-blend-screen opacity-[0.03] filter blur-[100px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="scroll-reveal max-w-2xl mb-16 md:mb-24">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-6 leading-tight">
        Sistemas que <span class="text-gradient-accent">transforman</span> tu forma de trabajar
      </h2>
      <p class="text-lg text-zinc-400 leading-relaxed">
        Soluciones técnicas de alto nivel diseñadas específicamente para automatizar, vender más y perder menos tiempo.
      </p>
    </div>

    {/* Bento Box Grid */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {servicios.map((s, i) => (
        <div class={`scroll-reveal glass-card rounded-3xl p-8 md:p-10 flex flex-col group relative overflow-hidden ${s.colSpan}`} style={`transition-delay: ${i * 100}ms`}>
          {/* Hover gradient effect */}
          <div class="absolute inset-0 bg-linear-to-br from-[--color-accent]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative z-10 flex-1">
            <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-[--color-accent] mb-8 group-hover:scale-110 group-hover:bg-[--color-accent]/10 transition-all duration-300">
              <div set:html={s.icon} />
            </div>
            
            <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-linear-to-r group-hover:from-white group-hover:to-zinc-400 transition-all">{s.titulo}</h3>
            <p class="text-zinc-400 leading-relaxed mb-8">{s.texto}</p>
          </div>

          <div class="relative z-10 flex flex-wrap gap-3 mt-auto">
            {s.tags.map(tag => (
              <span class="font-mono text-xs font-medium text-zinc-300 bg-white/5 border border-white/10 px-3 py-1.5 rounded-full backdrop-blur-sm group-hover:border-white/20 transition-colors">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="scroll-reveal mt-20 pt-10 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
      <div>
        <h4 class="text-xl font-medium text-white mb-2">¿No estás seguro por dónde empezar?</h4>
        <p class="text-zinc-400">Podemos hacer un diagnóstico de tus procesos sin ningún costo.</p>
      </div>
      <a href="#contacto" class="inline-flex items-center gap-2 bg-white text-zinc-950 font-semibold px-6 py-3 rounded-full transition-transform hover:scale-105">
        Agendar llamada
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
