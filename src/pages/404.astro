---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Página no encontrada | Nodo Digital" description="La página que buscas no existe.">
  <main class="min-h-[100dvh] flex flex-col items-center justify-center px-6 text-center">
    <span class="font-mono text-[11px] text-zinc-600 uppercase tracking-[0.2em] mb-6">Error 404</span>
    <h1 class="text-5xl md:text-7xl font-bold text-white tracking-tight mb-4 leading-tight">
      Página no encontrada
    </h1>
    <p class="text-zinc-500 max-w-md mb-10 leading-relaxed">
      La página que buscas no existe o fue movida. Vuelve al inicio para encontrar lo que necesitas.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 bg-[#5ed29c] text-[#070b0a] font-medium text-sm px-8 py-3.5 rounded-full transition-[background-color,box-shadow] duration-200 ease-out hover:bg-[#4cbf87] hover:shadow-[0_0_25px_rgba(94,210,156,0.12)] active:scale-[0.96]"
    >
      Volver al inicio
    </a>
  </main>
</Layout>
