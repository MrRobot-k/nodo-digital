    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Xolventa",
      "description": description,
      "url": domain,
      "image": ogImage,
      "telephone": "+528342550555",
