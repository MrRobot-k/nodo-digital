<file path="src/styles/global.css">
@import "tailwindcss";
@import "tw-animate-css";
@import "shadcn/tailwind.css";

@custom-variant dark (&:is(.dark *));

@theme inline {
  --font-sans: 'Geist Variable', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;

  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);
  --radius-sm: 2px;
  --radius-md: 2px;
  --radius-lg: 2px;
  --radius-xl: 2px;
}

:root {
  --color-canvas: #070b0a;
  --color-ink: #fafafa;
  --color-ink-2: #a1a1aa;
  --color-ink-3: #71717a;
  --color-accent: #5ed29c;
  --color-accent-h: #4cbf87;
  --color-accent-subtle: rgba(94, 210, 156, 0.08);
  --color-border: rgba(255, 255, 255, 0.06);

  --ease-out: cubic-bezier(0.23, 1, 0.32, 1);
  --ease-in-out: cubic-bezier(0.77, 0, 0.175, 1);
  --ease-spring: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-drawer: cubic-bezier(0.32, 0.72, 0, 1);

  --background: var(--color-canvas);
  --foreground: var(--color-ink);
  --card: rgba(255, 255, 255, 0.03);
  --card-foreground: var(--color-ink);
  --popover: var(--color-canvas);
  --popover-foreground: var(--color-ink);
  --primary: var(--color-accent);
  --primary-foreground: #070b0a;
  --secondary: rgba(255, 255, 255, 0.05);
  --secondary-foreground: var(--color-ink);
  --muted: rgba(255, 255, 255, 0.05);
  --muted-foreground: var(--color-ink-2);
  --accent: var(--color-accent-subtle);
  --accent-foreground: var(--color-accent);
  --destructive: #ef4444;
  --border: var(--color-border);
  --input: rgba(255, 255, 255, 0.1);
  --ring: var(--color-accent);
  --radius: 0px;
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }
  html {
    @apply scroll-smooth;
    color-scheme: dark;
  }
  body {
    @apply bg-background text-foreground font-sans antialiased;
  }
  h1, h2, h3, h4, h5, h6 {
    font-weight: 600;
    letter-spacing: -0.02em;
    text-wrap: balance;
    line-height: 1.05;
  }
  h1 {
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  p {
    text-wrap: pretty;
    line-height: 1.6;
  }
  ::selection {
    background: rgba(94, 210, 156, 0.15);
  }
  ::-moz-selection {
    background: rgba(94, 210, 156, 0.15);
  }
}

/* ── Emil Kowalski: Press feedback ── */
@layer base {
  button, a {
    -webkit-tap-highlight-color: transparent;
  }
}

/* ── Scroll reveals (opacity + translate) ── */
/* Content visible by default. JS applies hidden state, observer reveals it. */

.scroll-reveal {
  transition: opacity 0.8s var(--ease-spring),
              transform 0.8s var(--ease-spring);
}
.scroll-reveal.is-hidden {
  opacity: 0;
  transform: translateY(24px);
}
.scroll-reveal.revealed {
  opacity: 1;
  transform: translateY(0);
}

/* ── Clip reveals ── */
.clip-reveal {
  transition: clip-path 1.2s var(--ease-spring);
}
.clip-reveal.is-hidden {
  clip-path: inset(0 0 100% 0);
}
.clip-reveal.revealed {
  clip-path: inset(0 0 0 0);
}

.clip-reveal-right {
  transition: clip-path 1s var(--ease-out);
}
.clip-reveal-right.is-hidden {
  clip-path: inset(0 100% 0 0);
}
.clip-reveal-right.revealed {
  clip-path: inset(0 0 0 0);
}

.clip-reveal-top {
  transition: clip-path 0.8s var(--ease-out);
}
.clip-reveal-top.is-hidden {
  clip-path: inset(100% 0 0 0);
}
.clip-reveal-top.revealed {
  clip-path: inset(0 0 0 0);
}

/* ── Stagger children ── */
.stagger-children > * {
  transition: opacity 0.6s var(--ease-spring),
              transform 0.6s var(--ease-spring);
}
.stagger-children.is-hidden > * {
  opacity: 0;
  transform: translateY(20px);
}
.stagger-children.revealed > *:nth-child(1) { transition-delay: 0ms; }
.stagger-children.revealed > *:nth-child(2) { transition-delay: 60ms; }
.stagger-children.revealed > *:nth-child(3) { transition-delay: 120ms; }
.stagger-children.revealed > *:nth-child(4) { transition-delay: 180ms; }
.stagger-children.revealed > *:nth-child(5) { transition-delay: 240ms; }
.stagger-children.revealed > *:nth-child(6) { transition-delay: 300ms; }
.stagger-children.revealed > * {
  opacity: 1;
  transform: translateY(0);
}

/* ── Card hover effect ── */
.hover-card {
  transition: transform 0.4s var(--ease-out),
              border-color 0.4s var(--ease-out),
              box-shadow 0.4s var(--ease-out);
  will-change: transform;
}
.hover-card:hover {
  transform: translateY(-4px);
  border-color: rgba(94, 210, 156, 0.15);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

/* ── Grain texture overlay ── */
.grain-overlay::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 9999;
  pointer-events: none;
  opacity: 0.035;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 256px 256px;
}

/* ── Scrollbar styling ── */
::-webkit-scrollbar {
  width: 4px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: rgba(94, 210, 156, 0.2);
  border-radius: 2px;
}
::-webkit-scrollbar-thumb:hover {
  background: rgba(94, 210, 156, 0.4);
}

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.1s !important;
  }
  .scroll-reveal,
  .scroll-reveal.is-hidden,
  .clip-reveal,
  .clip-reveal.is-hidden,
  .clip-reveal-right,
  .clip-reveal-right.is-hidden,
  .clip-reveal-top,
  .clip-reveal-top.is-hidden,
  .stagger-children > *,
  .stagger-children.is-hidden > * {
    opacity: 1 !important;
    transform: none !important;
    clip-path: inset(0) !important;
  }
}
</file>

